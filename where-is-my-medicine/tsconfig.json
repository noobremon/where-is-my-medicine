{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "skipLibCheck": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@wimm/shared": [
                "packages/shared/src/index.ts"
            ],
            "@wimm/firebase-config": [
                "packages/firebase-config/src/index.ts"
            ]
        }
    },
    "include": [
        "packages/shared/src/**/*.ts",
        "packages/firebase-config/src/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}